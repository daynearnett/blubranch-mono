# Files to exclude from the Docker build context. Smaller context =
# faster uploads + faster `COPY . .` + tighter cache invalidation.
#
# Anything we want IN the image must NOT match a line below.

# Dependencies — Docker installs fresh inside the build
node_modules
**/node_modules

# Build outputs from local development
dist
**/dist
build
**/build
.next
**/.next
.turbo
**/.turbo

# Expo / mobile artifacts (not needed for API image)
.expo
**/.expo
.expo-shared
**/.expo-shared
web-build
**/web-build

# Generated Prisma client — regenerated inside the build
packages/db/src/generated

# Local env (the image gets vars from Railway at runtime)
.env
.env.*
!.env.example

# Image upload directory — created at runtime
uploads

# Editor / OS noise
.DS_Store
*.log
.vscode
.idea

# VCS metadata — not needed in the image
.git
.github
.gitignore
.gitattributes

# Repo-level docs / readmes don't need to be in the image
docs
*.md

# Mobile + admin builds aren't part of the API image
apps/mobile/.expo
apps/mobile/dist
apps/admin/dist
