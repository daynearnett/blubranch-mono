# --- API server ---
PORT=4000
NODE_ENV=development

# --- Database ---
# Local docker-compose default — see docker-compose.yml
DATABASE_URL=postgresql://blubranch:blubranch@localhost:5432/blubranch?schema=public

# --- Cache / queues ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=replace-me-with-a-long-random-string

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Publishable key handed to the mobile Payment Sheet (pk_test_… / pk_live_…)
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
# Recurring Price ids for the monthly subscription tiers (create in Stripe dashboard)
STRIPE_PRICE_PRO=price_replace_me
STRIPE_PRICE_UNLIMITED=price_replace_me
# Mobile build also needs this as a public env var (apps/mobile/.env or EAS):
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# --- Twilio ---
TWILIO_ACCOUNT_SID=ACreplace_me
TWILIO_AUTH_TOKEN=replace_me

# --- Email (Resend) ---
RESEND_API_KEY=re_replace_me

# --- Twilio Verify (phone verification on apply flow) ---
TWILIO_VERIFY_SERVICE_SID=VA_replace_me

# --- Push notifications (Firebase Cloud Messaging) ---
FIREBASE_PROJECT_ID=blubranch-dev
# Stringified Firebase service account JSON — used by firebase-admin
FIREBASE_SERVICE_ACCOUNT_JSON={}

# --- Google Maps / geocoding ---
GOOGLE_MAPS_API_KEY=replace_me

# --- Content moderation (OpenAI omni-moderation, free) ---
# Auto-blocks high-confidence explicit/violent text + images on post/upload.
# Unset = moderation disabled (fail-open). Get a key at platform.openai.com.
OPENAI_API_KEY=sk-replace_me
