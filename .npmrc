# Expo + React Native expect a flat node_modules. With pnpm's default symlinked
# layout, transitive peers like expo-font/build/server, @react-navigation/native,
# react-native-screens, etc. fail to resolve at build time.
#
# `node-linker=hoisted` tells pnpm to write a flat node_modules (npm-style) so
# Metro's resolver behaves like it does for any RN project. Recommended by Expo
# for pnpm monorepos.
node-linker=hoisted
