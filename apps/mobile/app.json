{
  "expo": {
    "name": "BluBranch",
    "slug": "blubranch",
    "version": "0.1.5",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "scheme": "blubranch",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#3D5A80"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.blubranch.app",
      "buildNumber": "3",
      "usesAppleSignIn": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "BluBranch uses your location to show jobs near you and set the city on your profile. Your exact location is never shared — only your city and region.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.blubranch.app",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3D5A80"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "BluBranch needs access to your photos so you can upload work portfolio shots and your profile picture.",
          "cameraPermission": "BluBranch needs access to your camera so you can capture work site photos."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#3D5A80",
          "image": "./assets/splash.png",
          "imageWidth": 220
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FFCD11",
          "androidMode": "default",
          "androidCollapsedTitle": "BluBranch"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1",
            "useFrameworks": "static",
            "forceStaticLinking": [
              "RNFBApp",
              "RNFBMessaging"
            ]
          },
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ],
      [
        "@react-native-firebase/app",
        {
          "ios": {
            "googleServicesFile": "./GoogleService-Info.plist"
          },
          "android": {
            "googleServicesFile": "./google-services.json"
          }
        }
      ],
      "@react-native-firebase/messaging",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "",
          "enableGooglePay": false
        }
      ],
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.REPLACE_WITH_IOS_CLIENT_ID"
        }
      ],
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "c623a781-b1cf-46a2-901a-b0b6f6e923d1"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "daynearnett",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c623a781-b1cf-46a2-901a-b0b6f6e923d1"
    }
  }
}
