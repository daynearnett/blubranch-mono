{
  "name": "@blubranch/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "migrate": "pnpm --filter @blubranch/db exec prisma migrate deploy",
    "seed": "pnpm --filter @blubranch/db exec prisma db seed",
    "lint": "eslint src",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@blubranch/db": "workspace:*",
    "@blubranch/shared": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/sensible": "^6.0.2",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.2.0",
    "jsonwebtoken": "^9.0.2",
    "resend": "^6.12.3",
    "sharp": "^0.34.5",
    "tsx": "^4.19.2",
    "twilio": "^5.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/sharp": "^0.32.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
